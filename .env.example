# UrbanNest AI — Environment Variables
# Copy to .env and fill in all REQUIRED values.
# Never commit .env to git.

# ── Gemini AI (REQUIRED) ──────────────────────────────────────────
# Get free key at: https://aistudio.google.com
# IMPORTANT: Use gemini-2.0-flash via v1beta — NOT v1/gemini-1.5-flash-latest (deprecated → 404)
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_KEY=your_gemini_api_key_here    # Same key, exposed to Vite frontend

# ── Database (REQUIRED) ───────────────────────────────────────────
# Local dev: postgresql://urbannest:secret123@localhost:5432/urbannest
# Render:    Get from dashboard after creating PostgreSQL instance
DATABASE_URL=postgresql://urbannest:secret123@localhost:5432/urbannest
DB_PASSWORD=secret123

# ── Redis (REQUIRED for Celery workers) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000          # Change to https://your-backend.onrender.com for prod

# ── Auth ─────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-32-char-random-secret-in-production
ADMIN_KEY=admin-secret-for-ingest-endpoints

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Scraper RapidAPI (Optional — enables Zoopla API for UK) ──────
RAPIDAPI_KEY=your_rapidapi_key_here         # Get at rapidapi.com
SCRAPER_DELAY_SECS=2.0                      # Delay between scrape requests (be polite)

# ── Email Alerts (Optional) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password                 # Gmail: use App Password not account password

# ── Storage ───────────────────────────────────────────────────────
FAISS_INDEX_PATH=/data/faiss.index          # Path for FAISS vector index
APP_URL=https://your-app.vercel.app         # Used in alert email links

# ── Deployment ────────────────────────────────────────────────────
# Render auto-sets PORT for backend — don't set PORT here
# For Vercel, set VITE_GEMINI_KEY and VITE_API_BASE in project settings
