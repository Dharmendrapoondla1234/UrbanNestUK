# ─── Force LF line endings for all text files ────────────────
# This stops the "LF will be replaced by CRLF" warnings on Windows

* text=auto eol=lf

# ─── Explicitly LF ───────────────────────────────────────────
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.env*    text eol=lf
*.txt     text eol=lf

# ─── Binary — never touch line endings ───────────────────────
*.pkl     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.zip     binary
*.gz      binary
*.tar     binary
